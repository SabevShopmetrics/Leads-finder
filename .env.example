# Copy this file to ".env" and paste your real key.
# Get one at: https://console.cloud.google.com/  (enable "Places API (New)")
# The .env file is git-ignored — never commit your real key.
GOOGLE_PLACES_API_KEY=your-api-key-here

# Optional overrides (uncomment to change defaults):
# Max results collected per query (Google returns 20 per page, so this rounds up to a multiple of 20).
# MAX_RESULTS_PER_QUERY=60
# Milliseconds to wait between API calls (polite rate-limiting).
# REQUEST_DELAY_MS=1200
# Language + region bias for results.
# LANGUAGE_CODE=bg
# REGION_CODE=BG
